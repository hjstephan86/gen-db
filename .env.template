# Gen-DB Configuration Template
# Kopiere diese Datei zu .env und passe die Werte an

# =============================================================================
# Subgraph C++ Executor
# =============================================================================

# Pfad zur subgraph-cli Binary (absolute oder relative Pfad)
SUBGRAPH_CLI_PATH=../csubgraph-main/build/subgraph-cli

# Anzahl der ProcessPoolExecutor Worker (default: cpu_count)
# Für CPU-bound: cpu_count
# Für I/O-bound: cpu_count * 2-4
SUBGRAPH_MAX_WORKERS=4

# Timeout für einen Subgraph-Vergleich in Sekunden
SUBGRAPH_TIMEOUT=30

# =============================================================================
# PostgreSQL Database
# =============================================================================

# Connection Parameter
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=gendb

# Connection Pool Size
DATABASE_POOL_SIZE=10
DATABASE_POOL_RECYCLE=3600

# SSL Mode (disable, allow, prefer, require)
DATABASE_SSL_MODE=disable

# =============================================================================
# FastAPI Application
# =============================================================================

# App Debug Mode
DEBUG=True

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# API Host und Port
API_HOST=0.0.0.0
API_PORT=8000

# Number of Uvicorn Workers (für Production)
# Für Development: 1
# Für Production: 2-4 (oder 2 * cpu_count)
UVICORN_WORKERS=1

# Uvicorn Worker Class (uvicorn.workers.UvicornWorker, UvicornH11Worker, etc.)
UVICORN_WORKER_CLASS=uvicorn.workers.UvicornWorker

# =============================================================================
# CORS (Cross-Origin Resource Sharing)
# =============================================================================

# Erlaubte Origins (komma-separiert)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000

# Erlaubte Methods
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Erlaubte Headers
CORS_HEADERS=Content-Type,Authorization

# Credentials erlauben
CORS_CREDENTIALS=true

# =============================================================================
# API Rate Limiting (optional)
# =============================================================================

# Rate Limit: Requests pro Minute pro IP
RATE_LIMIT_REQUESTS=300

# Rate Limit: Fenster in Minuten
RATE_LIMIT_WINDOW=1

# =============================================================================
# Monitoring & Observability
# =============================================================================

# Enable Prometheus Metrics
ENABLE_PROMETHEUS=false

# Prometheus Port
PROMETHEUS_PORT=9090

# Enable Request Tracking
ENABLE_REQUEST_TRACKING=true

# =============================================================================
# Security
# =============================================================================

# Secret Key für JWT (falls verwendet)
SECRET_KEY=your-secret-key-change-this-in-production

# Max Upload Size (bytes)
MAX_UPLOAD_SIZE=10485760  # 10MB

# =============================================================================
# Docker / Container Specific
# =============================================================================

# Container Environment
CONTAINER_ENV=production  # development, staging, production

# Restart Policy
RESTART_POLICY=unless-stopped

# =============================================================================
# Development Only
# =============================================================================

# Reload API on Code Change
RELOAD=true

# Show SQL Queries
SHOW_SQL=false

# Generate Fake Data on Startup
GENERATE_FAKE_DATA=false

# Number of Fake Networks to Generate
FAKE_DATA_COUNT=10

# =============================================================================
# Email Notifications (optional)
# =============================================================================

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@gen-db.local

# =============================================================================
# Backup & Maintenance
# =============================================================================

# Automatic Backup Schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *  # 2 AM daily

# Backup Retention Days
BACKUP_RETENTION_DAYS=30

# =============================================================================
# Haproxy (falls verwendet)
# =============================================================================

HAPROXY_ENABLED=false
HAPROXY_PORT=8080

# =============================================================================
# Hinweise:
# =============================================================================
# 
# 1. Diese Datei sollte NICHT in Git committet werden
#    Nutze: echo ".env" >> .gitignore
#
# 2. Für Production: Verwende sichere Passwörter
#    openssl rand -base64 32  # Generiert sicheres Passwort
#
# 3. DATABASE_PASSWORD sollte mindestens 16 Zeichen lang sein
#
# 4. SECRET_KEY muss geheim bleiben und beim Deployment gesetzt werden
#
# 5. Docker verwendet diese Werte automatisch
#    docker-compose liest .env automatisch
#
# 6. Lokal: Manuell laden mit:
#    export $(cat .env | grep -v '^#' | xargs)
#
# =============================================================================
